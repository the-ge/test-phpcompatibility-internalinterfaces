{
    "name": "thege/test-phpcompatibility-internalinterfaces",
    "description": "Fluent HTML builder for PHP 8.4+",
    "type": "library",
    "homepage": "https://github.com/the-ge/widgettery",
    "license": "MIT",
    "authors": [
        {
            "name": "Gabriel Tenita",
            "email": "the.ge.1447624801@tenita.eu",
            "homepage": "https://www.tenita.eu"
        }
    ],
    "support": {
        "issues": "https://github.com/the-ge/test-phpcompatibility-internalinterfaces"
    },
    "require": {
        "php": ">=8.4.0"
    },
    "autoload": {
        "psr-4": {
            "TestExtendingInternalInterface\\": "src/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpcompatibility/php-compatibility": "^10.0.0@dev"
    },
    "config": {  
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }  
    },
    "scripts": {
        "stan": "vendor/bin/phpstan analyse src",
        "compat": "vendor/bin/phpcs -p src --standard=PHPCompatibility --runtime-set testVersion 8.4"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
